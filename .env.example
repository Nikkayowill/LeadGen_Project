NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public deploy access control.
# Keep APP_PUBLIC_DEMO=false for protected deployments.
APP_ACCESS_USERNAME=nikkayo
APP_ACCESS_PASSWORD=
APP_PUBLIC_DEMO=false

# Local-only admin mode. Keep this false if you deploy publicly.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USE_SERVICE_ROLE=false

# Optional for scoping Supabase MCP setup later.
SUPABASE_PROJECT_REF=

# Optional lead discovery providers.
# Paid providers stay disabled unless LEAD_FINDER_ENABLE_PAID_PROVIDERS is true.
# Keep this false for public demos unless you have strict Google/Yelp billing quotas set.
LEAD_FINDER_ENABLE_PAID_PROVIDERS=false
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_DAILY_LIMIT=10
GOOGLE_PLACES_MAX_RESULTS=5
YELP_API_KEY=
YELP_DAILY_LIMIT=10
YELP_MAX_RESULTS=5
# Auto mode stays free-only unless both paid providers and paid auto fallback are enabled.
LEAD_FINDER_ALLOW_PAID_AUTO=false

# Set your local Supabase database password in .env.local.
SUPABASE_DB_PASS=

# Security controls.
# Leave ALLOWED_ORIGINS empty for same-origin only. Add comma-separated origins if you intentionally
# expose the app behind more than one trusted browser origin.
ALLOWED_ORIGINS=
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_REQUESTS_PER_HOUR=60
